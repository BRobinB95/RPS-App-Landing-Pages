<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Privacy Policy — Rock Paper Scissors</title>
  <meta name="description" content="Privacy Policy for the Rock Paper Scissors iOS app.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;800&family=Inter:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0A0A1A;
      --surface:   #12122A;
      --border:    rgba(255,255,255,0.07);
      --purple:    #A78BFA;
      --blue:      #60A5FA;
      --pink:      #F472B6;
      --text:      #E0E0FF;
      --muted:     #6B6B8A;
      --radius:    14px;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      line-height: 1.7;
      min-height: 100vh;
    }

    /* NAV */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 40px;
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 800;
      font-size: 0.9rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: linear-gradient(90deg, var(--purple), var(--blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-decoration: none;
    }

    .nav-back {
      font-size: 0.82rem;
      color: var(--muted);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: color 0.2s;
    }

    .nav-back:hover { color: var(--text); }

    /* HERO */
    .page-hero {
      padding: 64px 40px 48px;
      max-width: 800px;
      margin: 0 auto;
      border-bottom: 1px solid var(--border);
    }

    .page-eyebrow {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--purple);
      margin-bottom: 12px;
    }

    .page-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }

    .page-meta {
      font-size: 0.82rem;
      color: var(--muted);
    }

    /* CONTENT */
    .content {
      max-width: 800px;
      margin: 0 auto;
      padding: 56px 40px 100px;
    }

    .toc {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px 28px;
      margin-bottom: 56px;
    }

    .toc-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 14px;
    }

    .toc ol {
      list-style: decimal;
      padding-left: 20px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .toc a {
      color: var(--purple);
      font-size: 0.88rem;
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .toc a:hover { opacity: 0.75; }

    .policy-section {
      margin-bottom: 52px;
      scroll-margin-top: 80px;
    }

    .policy-section h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }

    .policy-section p {
      font-size: 0.92rem;
      color: #B0B0CC;
      margin-bottom: 14px;
    }

    .policy-section ul {
      list-style: none;
      padding: 0;
      margin-bottom: 14px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .policy-section ul li {
      font-size: 0.92rem;
      color: #B0B0CC;
      padding-left: 20px;
      position: relative;
    }

    .policy-section ul li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: var(--muted);
    }

    .policy-section strong { color: var(--text); }

    .highlight-box {
      background: rgba(167,139,250,0.08);
      border: 1px solid rgba(167,139,250,0.2);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin: 20px 0;
      font-size: 0.9rem;
      color: #C0C0E0;
    }

    .highlight-box strong {
      color: var(--purple);
      display: block;
      margin-bottom: 6px;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    /* FOOTER */
    footer {
      border-top: 1px solid var(--border);
      padding: 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }

    .footer-logo {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 800;
      font-size: 0.85rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: linear-gradient(90deg, var(--purple), var(--blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .footer-links {
      display: flex;
      gap: 24px;
      list-style: none;
    }

    .footer-links a {
      color: var(--muted);
      font-size: 0.8rem;
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-links a:hover { color: var(--text); }

    @media (max-width: 640px) {
      nav, .page-hero, .content, footer { padding-left: 20px; padding-right: 20px; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="index.html" class="nav-logo">RPS</a>
    <a href="index.html" class="nav-back">← Back to home</a>
